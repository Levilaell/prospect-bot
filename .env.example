GOOGLE_MAPS_API_KEY=    # Google Places API + PageSpeed Insights
ANTHROPIC_API_KEY=      # Claude API
SUPABASE_URL=           # Supabase project URL
SUPABASE_SERVICE_KEY=   # Supabase service role key (not anon)
INSTANTLY_API_KEY=      # Instantly.ai API key (Settings → API Keys)
INSTANTLY_CAMPAIGN_ID=  # Campaign ID to add leads to (Campaigns → select → URL)
HUNTER_API_KEY=         # Hunter.io API key (hunter.io/api-keys) — optional, enables email enrichment fallback
EVOLUTION_API_URL=      # Evolution API base URL (e.g. http://localhost:8080)
EVOLUTION_API_KEY=      # Evolution API key
EVOLUTION_INSTANCE=     # WhatsApp instance name

# URL do CRM (sem trailing slash)
CRM_API_URL=https://admin.fastdevbuilds.com
# Shared secret com o CRM. Gerar com: openssl rand -hex 32
BOT_TO_CRM_SECRET=
